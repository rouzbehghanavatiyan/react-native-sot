{
  "expo": {
    "name": "clashtalent",
    "slug": "clashtalent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logocircle.png",
    "scheme": "clashtalent",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/assets/images/logocircle.png",
        "backgroundImage": "./src/assets/images/bronze-3.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "clashtalent.com",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#ffffff"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/logocircle.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-video",
      "react-native-compressor"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b50a5b2e-c16d-4cda-962e-24676e8fd1e1"
      }
    },
    "owner": "rouzbehghanavatiyan"
  }
}
